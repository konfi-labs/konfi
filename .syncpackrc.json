{
  "$schema": "./node_modules/syncpack/schema.json",
  "source": [
    "package.json",
    "apps/*/package.json",
    "packages/*/package.json",
    "!apps/functions/.deploy*/**",
    "!apps/functions/isolate/**",
    "!**/dist/**",
    "!**/build/**",
    "!**/client/**"
  ],
  "versionGroups": [
    {
      "label": "Konfi workspace packages must use the workspace protocol",
      "dependencies": ["@konfi/**", "@sblyvwx/cloud-contracts"],
      "dependencyTypes": ["dev", "prod", "peer"],
      "pinVersion": "workspace:*"
    },
    {
      "label": "Shared third-party dependencies must use the default pnpm catalog",
      "policy": "catalog",
      "dependencies": [
        "@ai-sdk/devtools",
        "@ai-sdk/google",
        "@ai-sdk/google-vertex",
        "@ai-sdk/react",
        "@chakra-ui/charts",
        "@chakra-ui/cli",
        "@chakra-ui/react",
        "@emotion/react",
        "@firebase/rules-unit-testing",
        "@hookform/resolvers",
        "@manypkg/cli",
        "@mdx-js/mdx",
        "@microsoft/kiota-abstractions",
        "@microsoft/kiota-bundle",
        "@microsoft/kiota-http-fetchlibrary",
        "@microsoft/kiota-serialization-form",
        "@microsoft/kiota-serialization-json",
        "@microsoft/kiota-serialization-multipart",
        "@microsoft/kiota-serialization-text",
        "@modelcontextprotocol/sdk",
        "@next/third-parties",
        "@sentry/nextjs",
        "@tanstack/react-table",
        "@tanstack/table-core",
        "@testing-library/dom",
        "@testing-library/jest-dom",
        "@testing-library/react",
        "@testing-library/user-event",
        "@tsconfig/node20",
        "@types/node",
        "@types/react",
        "@types/react-dom",
        "@vitejs/plugin-react",
        "ai",
        "babel-plugin-react-compiler",
        "better-all",
        "cross-env",
        "dotenv-cli",
        "es-toolkit",
        "eslint-plugin-turbo",
        "firebase",
        "firebase-admin",
        "i18next",
        "jsdom",
        "next",
        "next-mdx-remote",
        "oxfmt",
        "oxlint",
        "react",
        "react-dom",
        "react-hook-form",
        "react-i18next",
        "react-images-uploading",
        "react-swipeable",
        "resend",
        "streamdown",
        "stripe",
        "swr",
        "turbo",
        "typescript",
        "vitest",
        "vitest-axe",
        "workflow",
        "yup",
        "zod"
      ],
      "dependencyTypes": ["dev", "prod", "peer"]
    },
    {
      "label": "Other dependencies are not enforced by Syncpack",
      "dependencies": ["**"],
      "isIgnored": true
    }
  ]
}
