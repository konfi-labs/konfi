rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSuperAdmin()
        || isSignedIn()
          && request.auth.token.admin == true
          && request.auth.token.accessLevel >= 1;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.admin == true
        && request.auth.token.accessLevel == 9999;
    }

    // Dedicated/default runtime data may not have tenantMemberships records.
    // This ruleset is safe to bridge with every normal admin only when
    // tenantless and tenantId=="default" data belongs to that same runtime.
    // If the database mixes unrelated tenant admins with default runtime data,
    // narrow this helper with an explicit custom claim such as dedicated == true.
    function isDedicatedDefaultAdmin() {
      return isAdmin();
    }

    function isCourier() {
      return isSignedIn() && request.auth.token.courier == true;
    }

    function isUser(customerId) {
      return isSignedIn() && request.auth.uid == customerId;
    }

    function isSignedInOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function membershipPath(tenantId) {
      return /databases/$(database)/documents/tenantMemberships/$(tenantId + "_" + request.auth.uid);
    }

    function hasTenantId(data) {
      return data.keys().hasAny(["tenantId"])
        && data.tenantId is string
        && data.tenantId.size() > 0;
    }

    function hasSourceTenantId(data) {
      return data.keys().hasAny(["sourceTenantId"])
        && data.sourceTenantId is string
        && data.sourceTenantId.size() > 0;
    }

    function hasTargetTenantId(data) {
      return data.keys().hasAny(["targetTenantId"])
        && data.targetTenantId is string
        && data.targetTenantId.size() > 0;
    }

    function hasSameTenantId() {
      return hasTenantId(resource.data)
        && hasTenantId(request.resource.data)
        && request.resource.data.tenantId == resource.data.tenantId;
    }

    function isDedicatedDefaultTenant(tenantId) {
      return tenantId == "default";
    }

    // Dedicated instance documents can be tenantless; default runtime documents
    // use tenantId=="default". Keep this compatibility path scoped to those
    // documents so hosted SaaS tenant data still requires tenantMemberships.
    function isDedicatedDefaultTenantDocument(data) {
      return !hasTenantId(data) || isDedicatedDefaultTenant(data.tenantId);
    }

    function hasDedicatedDefaultTenantAccess(tenantId) {
      return isDedicatedDefaultAdmin()
        && tenantId is string
        && isDedicatedDefaultTenant(tenantId);
    }

    function canDedicatedDefaultAdminAccess(data) {
      return isDedicatedDefaultAdmin() && isDedicatedDefaultTenantDocument(data);
    }

    function hasActiveTenantMembership(tenantId) {
      return isSignedIn()
        && tenantId is string
        && exists(membershipPath(tenantId))
        && get(membershipPath(tenantId)).data.status == "ACTIVE";
    }

    function membershipHasFullTenantScope(membership) {
      return membership.role == "OWNER"
        || !membership.keys().hasAny(["channelIds"])
        || membership.channelIds.size() == 0;
    }

    function membershipCanAccessChannel(membership, channelId) {
      return membershipHasFullTenantScope(membership)
        || membership.keys().hasAny(["channelIds"])
          && membership.channelIds.hasAny([channelId]);
    }

    function hasTenantAdminMembership(tenantId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in ["OWNER", "ADMIN"];
    }

    function hasTenantOwnerMembership(tenantId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role == "OWNER";
    }

    function hasTenantStaffMembership(tenantId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in [
          "OWNER",
          "ADMIN",
          "MEMBER",
          "COURIER",
        ];
    }

    function hasFullTenantAdminMembership(tenantId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in ["OWNER", "ADMIN"]
        && membershipHasFullTenantScope(get(membershipPath(tenantId)).data);
    }

    function hasFullTenantStaffMembership(tenantId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in [
          "OWNER",
          "ADMIN",
          "MEMBER",
          "COURIER",
        ]
        && membershipHasFullTenantScope(get(membershipPath(tenantId)).data);
    }

    function hasTenantChannelAdminMembership(tenantId, channelId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in ["OWNER", "ADMIN"]
        && membershipCanAccessChannel(
          get(membershipPath(tenantId)).data,
          channelId
        );
    }

    function hasTenantChannelStaffMembership(tenantId, channelId) {
      return isAdmin()
        && hasActiveTenantMembership(tenantId)
        && get(membershipPath(tenantId)).data.role in [
          "OWNER",
          "ADMIN",
          "MEMBER",
          "COURIER",
        ]
        && membershipCanAccessChannel(
          get(membershipPath(tenantId)).data,
          channelId
        );
    }

    function membershipDataHasPermission(membership, permission) {
      return membership.role == "OWNER"
        || membership.role == "ADMIN"
          && (
            !membership.keys().hasAny(["permissions"])
            || membership.permissions.hasAny([permission])
          );
    }

    // Keep the dedicated/default fallback here as well as in document helpers:
    // counters, channel-scoped writes, and similar metadata paths can check
    // only tenantId or tenantId+channelId instead of a full document.
    function hasTenantWidePermission(tenantId, permission) {
      return isSuperAdmin()
        || hasDedicatedDefaultTenantAccess(tenantId)
        || isAdmin()
          && hasActiveTenantMembership(tenantId)
          && membershipHasFullTenantScope(get(membershipPath(tenantId)).data)
          && membershipDataHasPermission(
            get(membershipPath(tenantId)).data,
            permission
          );
    }

    function hasTenantPermission(tenantId, permission) {
      return isSuperAdmin()
        || hasDedicatedDefaultTenantAccess(tenantId)
        || isAdmin()
          && hasActiveTenantMembership(tenantId)
          && membershipDataHasPermission(
            get(membershipPath(tenantId)).data,
            permission
          );
    }

    function hasTenantChannelPermission(tenantId, channelId, permission) {
      return isSuperAdmin()
        || hasDedicatedDefaultTenantAccess(tenantId)
        || isAdmin()
          && hasActiveTenantMembership(tenantId)
          && membershipCanAccessChannel(
            get(membershipPath(tenantId)).data,
            channelId
          )
          && membershipDataHasPermission(
            get(membershipPath(tenantId)).data,
            permission
          );
    }

    function canAdminReadTenantDocument(data) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || isAdmin()
          && hasTenantId(data)
          && hasFullTenantStaffMembership(data.tenantId);
    }

    function hasPaidCooperationPlans(data) {
      return data.sourcePlanId in ["starter", "pro", "enterprise"]
        && data.targetPlanId in ["starter", "pro", "enterprise"];
    }

    function canAdminReadCooperationDocument(data) {
      return isSuperAdmin()
        || isAdmin()
          && hasPaidCooperationPlans(data)
          && (
            (
              hasSourceTenantId(data)
              && hasTenantStaffMembership(data.sourceTenantId)
            )
            || (
              hasTargetTenantId(data)
              && hasTenantStaffMembership(data.targetTenantId)
            )
          );
    }

    function canAdminReadFulfillmentRequest(data) {
      return canAdminReadTenantDocument(data)
        || (
          hasSourceTenantId(data)
          && hasTenantStaffMembership(data.sourceTenantId)
        )
        || (
          hasTargetTenantId(data)
          && hasTenantStaffMembership(data.targetTenantId)
        );
    }

    function canAdminWriteTenantDocument(data) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || isAdmin()
          && hasTenantId(data)
          && hasFullTenantAdminMembership(data.tenantId);
    }

    function canUpdateTenantDocument() {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(resource.data)
          && canDedicatedDefaultAdminAccess(request.resource.data)
        || hasSameTenantId()
          && canAdminWriteTenantDocument(request.resource.data);
    }

    function canAdminCreateTenantDocumentWithPermission(data, permission) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || hasTenantId(data) && hasTenantWidePermission(data.tenantId, permission);
    }

    function canAdminCreateCustomer(data) {
      return canAdminCreateTenantDocumentWithPermission(
        data,
        "customers.manage"
      )
        || canAdminCreateTenantDocumentWithPermission(data, "orders.manage");
    }

    function canAdminUpdateTenantDocumentWithPermission(permission) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(resource.data)
          && canDedicatedDefaultAdminAccess(request.resource.data)
        || hasSameTenantId()
          && hasTenantWidePermission(request.resource.data.tenantId, permission);
    }

    function isValidNumberCounter(data) {
      return data.keys().hasOnly(["nextNumber", "tenantId"])
        && data.nextNumber is int
        && data.nextNumber >= 0;
    }

    function channelPath(channelId) {
      return /databases/$(database)/documents/channels/$(channelId);
    }

    function getChannelData(channelId) {
      return get(channelPath(channelId)).data;
    }

    function orderPath(channelId, orderId) {
      return /databases/$(database)/documents/channels/$(channelId)/orders/$(orderId);
    }

    function getOrderData(channelId, orderId) {
      return get(orderPath(channelId, orderId)).data;
    }

    function hasSameTenantAsChannel(channelId, data) {
      return exists(channelPath(channelId))
        && (
          hasTenantId(data)
            && hasTenantId(getChannelData(channelId))
            && data.tenantId == getChannelData(channelId).tenantId
          || hasTenantId(data)
            && isDedicatedDefaultTenant(data.tenantId)
            && isDedicatedDefaultTenantDocument(getChannelData(channelId))
          || !hasTenantId(data)
            && isDedicatedDefaultTenantDocument(getChannelData(channelId))
        );
    }

    function hasSameTenantAsOrder(channelId, orderId, data) {
      return exists(orderPath(channelId, orderId))
        && (
          hasTenantId(data)
            && hasTenantId(getOrderData(channelId, orderId))
            && data.tenantId == getOrderData(channelId, orderId).tenantId
          || hasTenantId(data)
            && isDedicatedDefaultTenant(data.tenantId)
            && isDedicatedDefaultTenantDocument(getOrderData(channelId, orderId))
          || !hasTenantId(data)
            && isDedicatedDefaultTenantDocument(getOrderData(channelId, orderId))
        );
    }

    function canAdminReadChannelDocument(channelId, data) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || hasSameTenantAsChannel(channelId, data)
          && hasTenantId(getChannelData(channelId))
          && hasTenantChannelStaffMembership(
            getChannelData(channelId).tenantId,
            channelId
          );
    }

    function canAdminWriteChannelDocument(channelId, data) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || hasSameTenantAsChannel(channelId, data)
          && hasTenantId(getChannelData(channelId))
          && hasTenantChannelAdminMembership(
            getChannelData(channelId).tenantId,
            channelId
          );
    }

    function canUpdateChannelDocument(channelId) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(resource.data)
          && canDedicatedDefaultAdminAccess(request.resource.data)
        || hasSameTenantId()
          && canAdminWriteChannelDocument(channelId, request.resource.data);
    }

    function canAdminCreateChannelDocumentWithPermission(channelId, data, permission) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || hasSameTenantAsChannel(channelId, data)
          && hasTenantId(getChannelData(channelId))
          && hasTenantChannelPermission(
            getChannelData(channelId).tenantId,
            channelId,
            permission
          );
    }

    function canAdminUpdateChannelDocumentWithPermission(channelId, permission) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(resource.data)
          && canDedicatedDefaultAdminAccess(request.resource.data)
        || hasSameTenantId()
          && hasSameTenantAsChannel(channelId, request.resource.data)
          && hasTenantId(getChannelData(channelId))
          && hasTenantChannelPermission(
            getChannelData(channelId).tenantId,
            channelId,
            permission
          );
    }

    function canAdminReadDefaultNumberCounter(counterId) {
      return counterId == "orders"
          && hasTenantPermission("default", "orders.manage")
        || counterId == "quotes"
          && hasTenantPermission("default", "quotes.manage");
    }

    function canAdminReadNumberCounter(channelId, counterId) {
      return counterId in ["orders", "quotes"]
        && exists(channelPath(channelId))
        && (
          canAdminReadChannelDocument(channelId, getChannelData(channelId))
          || isDedicatedDefaultTenantDocument(getChannelData(channelId))
            && canAdminReadDefaultNumberCounter(counterId)
        );
    }

    function canAdminCreateNumberCounter(data, channelId, counterId) {
      return isValidNumberCounter(data)
        && exists(channelPath(channelId))
        && (
          counterId == "orders"
            && (
              hasTenantId(getChannelData(channelId))
                && hasTenantId(data)
                && data.tenantId == getChannelData(channelId).tenantId
                && hasTenantChannelPermission(
                  getChannelData(channelId).tenantId,
                  channelId,
                  "orders.manage"
                )
              || isDedicatedDefaultTenantDocument(getChannelData(channelId))
                && hasTenantId(data)
                && isDedicatedDefaultTenant(data.tenantId)
                && hasTenantPermission("default", "orders.manage")
            )
          || counterId == "quotes"
            && (
              hasTenantId(getChannelData(channelId))
                && hasTenantId(data)
                && data.tenantId == getChannelData(channelId).tenantId
                && hasTenantChannelPermission(
                  getChannelData(channelId).tenantId,
                  channelId,
                  "quotes.manage"
                )
              || isDedicatedDefaultTenantDocument(getChannelData(channelId))
                && hasTenantId(data)
                && isDedicatedDefaultTenant(data.tenantId)
                && hasTenantPermission("default", "quotes.manage")
            )
        );
    }

    function canAdminUpdateNumberCounter(channelId, counterId) {
      return isValidNumberCounter(request.resource.data)
        && exists(channelPath(channelId))
        && (
          counterId == "orders"
            && (
              hasTenantId(getChannelData(channelId))
                && hasSameTenantAsChannel(channelId, request.resource.data)
                && hasTenantChannelPermission(
                  getChannelData(channelId).tenantId,
                  channelId,
                  "orders.manage"
                )
              || isDedicatedDefaultTenantDocument(getChannelData(channelId))
                && hasSameTenantAsChannel(channelId, request.resource.data)
                && hasTenantPermission("default", "orders.manage")
            )
          || counterId == "quotes"
            && (
              hasTenantId(getChannelData(channelId))
                && hasSameTenantAsChannel(channelId, request.resource.data)
                && hasTenantChannelPermission(
                  getChannelData(channelId).tenantId,
                  channelId,
                  "quotes.manage"
                )
              || isDedicatedDefaultTenantDocument(getChannelData(channelId))
                && hasSameTenantAsChannel(channelId, request.resource.data)
                && hasTenantPermission("default", "quotes.manage")
            )
        );
    }

    function canManageTenantMembership(data) {
      return isSuperAdmin()
        || hasTenantId(data)
          && hasTenantOwnerMembership(data.tenantId);
    }

    function canManageAiInstructions(data) {
      return isSuperAdmin()
        || canDedicatedDefaultAdminAccess(data)
        || hasTenantId(data)
          && hasTenantOwnerMembership(data.tenantId);
    }

    function customerPath(customerId) {
      return /databases/$(database)/documents/customers/$(customerId);
    }

    function customerExists(customerId) {
      return exists(customerPath(customerId));
    }

    function channelProductPath(channelId, productId) {
      return /databases/$(database)/documents/channels/$(channelId)/products/$(productId);
    }

    function getChannelProductData(channelId, productId) {
      return get(channelProductPath(channelId, productId)).data;
    }

    function canAdminReadChannelProduct(channelId, productId) {
      return exists(channelProductPath(channelId, productId))
        && canAdminReadChannelDocument(channelId, getChannelProductData(channelId, productId));
    }

    function canAdminWriteChannelProduct(channelId, productId) {
      return exists(channelProductPath(channelId, productId))
        && canAdminWriteChannelDocument(channelId, getChannelProductData(channelId, productId));
    }

    function isValidProductImageGenerationConfig(channelId, productId, data) {
      return data.keys().hasOnly([
        "enabled",
        "promptEnhancement",
        "tenantId",
        "updatedAt",
        "updatedBy",
      ])
        && data.enabled is bool
        && (!data.keys().hasAny(["promptEnhancement"])
          || data.promptEnhancement is string)
        && (!data.keys().hasAny(["tenantId"])
          || data.tenantId == getChannelProductData(channelId, productId).tenantId);
    }

    function customerHasTenant(customerId, tenantId) {
      return isUser(customerId)
        && tenantId is string
        && exists(customerPath(customerId))
        && (
          get(customerPath(customerId)).data.tenantId == tenantId
          || !hasTenantId(get(customerPath(customerId)).data)
            && isDedicatedDefaultTenant(tenantId)
        );
    }

    function canCustomerReadTenantDocument(data, customerId) {
      return isUser(customerId)
        && (!hasTenantId(data) || customerHasTenant(customerId, data.tenantId));
    }

    function canCustomerWriteTenantDocument(userId) {
      return isUser(userId)
        && (
          !hasTenantId(request.resource.data)
          || customerHasTenant(userId, request.resource.data.tenantId)
        );
    }

    function canCustomerReadCartDocument(data, userId) {
      return isUser(userId)
        && (
          isDedicatedDefaultTenantDocument(data)
          || customerHasTenant(userId, data.tenantId)
        );
    }

    function canCustomerWriteCartDocument(userId) {
      return isUser(userId)
        && (
          isDedicatedDefaultTenantDocument(request.resource.data)
          || customerHasTenant(userId, request.resource.data.tenantId)
        );
    }

    function canCustomerUpdateCartDocument(userId) {
      return isUser(userId)
        && (
          isDedicatedDefaultTenantDocument(resource.data)
          || hasSameTenantId()
        )
        && (
          isDedicatedDefaultTenantDocument(request.resource.data)
          || customerHasTenant(userId, request.resource.data.tenantId)
        );
    }

    function canCustomerDeleteCartDocument(userId) {
      return isUser(userId)
        && (
          isDedicatedDefaultTenantDocument(resource.data)
          || customerHasTenant(userId, resource.data.tenantId)
        );
    }

    function cartItemPath(userId, itemId) {
      return /databases/$(database)/documents/carts/$(userId)/items/$(itemId);
    }

    function canCustomerGetCartItem(data, userId, itemId) {
      return isUser(userId)
        && (
          !exists(cartItemPath(userId, itemId))
          || canCustomerReadCartDocument(data, userId)
        );
    }

    function isInCustomerOrders() {
      return isSignedIn()
        && resource.data.customer is map
        && resource.data.customer.id == request.auth.uid;
    }

    function canCustomerReadOrder() {
      return isInCustomerOrders()
        && (!hasTenantId(resource.data)
          || customerHasTenant(request.auth.uid, resource.data.tenantId));
    }

    function canCustomerReadRmaRequest(data) {
      return isSignedIn()
        && data.customerId == request.auth.uid
        && (!hasTenantId(data) || customerHasTenant(request.auth.uid, data.tenantId));
    }

    function canCourierReadTenantDocument(data) {
      return isCourier()
        && (!hasTenantId(data) || hasFullTenantStaffMembership(data.tenantId));
    }

    function canCourierReadChannelDocument(channelId, data) {
      return isCourier()
        && (!hasTenantId(data)
          || hasTenantChannelStaffMembership(data.tenantId, channelId));
    }

    function canCustomerUpdateReview() {
      return isSignedIn()
        && request.auth.uid == resource.data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "rating",
          "comment",
          "isRated",
        ])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.isRated is bool
        && (!request.resource.data.keys().hasAny(["comment"])
          || (request.resource.data.comment is string
            && request.resource.data.comment.size() <= 2000));
    }

    function canCreateB2BInquiry() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.businessDescription is string
        && request.resource.data.businessDescription.size() <= 10000
        && request.resource.data.billing is map
        && request.resource.data.status == "NEW"
        && request.resource.data.id is string
        && request.resource.data.createdBy is map
        && request.resource.data.updatedBy is map
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!hasTenantId(request.resource.data)
          || customerHasTenant(request.auth.uid, request.resource.data.tenantId))
        && request.resource.data.keys().hasOnly([
          "id",
          "tenantId",
          "userId",
          "businessDescription",
          "billing",
          "status",
          "createdBy",
          "updatedBy",
          "createdAt",
          "updatedAt",
        ]);
    }

    function canCreateAssistantConversation() {
      return isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.channelId is string
        && request.resource.data.channelId.size() <= 128
        && request.resource.data.modelId is string
        && request.resource.data.modelId.size() <= 128
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount >= 0
        && request.resource.data.lastMessageAt is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.active is bool
        && (!hasTenantId(request.resource.data)
          || customerHasTenant(request.auth.uid, request.resource.data.tenantId))
        && request.resource.data.keys().hasOnly([
          "title",
          "tenantId",
          "userId",
          "channelId",
          "modelId",
          "messageCount",
          "lastMessageAt",
          "createdAt",
          "updatedAt",
          "active",
        ]);
    }

    function canUpdateAssistantConversation() {
      return isSignedIn()
        && request.auth.uid == resource.data.userId
        && (!hasTenantId(resource.data)
          || customerHasTenant(request.auth.uid, resource.data.tenantId))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "title",
          "active",
          "updatedAt",
          "lastMessageAt",
          "messageCount",
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.active is bool
        && request.resource.data.messageCount is int
        && request.resource.data.messageCount >= resource.data.messageCount
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastMessageAt is timestamp;
    }

    function isAssistantConversationOwner(conversationId) {
      return isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/assistantConversations/$(conversationId)).data.userId;
    }

    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || hasTenantStaffMembership(tenantId);
      allow write: if isSuperAdmin();
    }

    match /tenantDomains/{hostname} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /tenantMemberships/{membershipId} {
      allow read: if isSuperAdmin()
        || isSignedIn() && resource.data.uid == request.auth.uid
        || hasTenantAdminMembership(resource.data.tenantId);
      allow create: if canManageTenantMembership(request.resource.data);
      allow update: if canManageTenantMembership(resource.data)
        && request.resource.data.tenantId == resource.data.tenantId
        && request.resource.data.uid == resource.data.uid;
      allow delete: if canManageTenantMembership(resource.data);
    }

    match /agents/{runId} {
      allow get: if canAdminReadTenantDocument(resource.data);
      allow list, create, update, delete: if isSuperAdmin();
    }

    match /agentMemories/{memoryId} {
      allow read: if resource.data.status == "active"
        && canAdminReadTenantDocument(resource.data);
