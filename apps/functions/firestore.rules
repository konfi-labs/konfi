    }

    match /designatedPickupAreas/{designatedPickupAreaId} {
      allow read: if canAdminReadTenantDocument(resource.data);
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if canAdminReadTenantDocument(resource.data);
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();
    }

    match /fakturowniaCostEvidence/{costEvidenceId} {
      allow read: if canAdminReadTenantDocument(resource.data);
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();
    }

    match /fakturowniaCostMappings/{costMappingId} {
      allow read: if canAdminReadTenantDocument(resource.data);
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();
    }

    match /blogPosts/{blogPostId} {
      allow read: if true;
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();

      match /{path=**}/translations/{translationId} {
        allow read: if true;
        allow create: if canAdminWriteTenantDocument(request.resource.data);
        allow update: if canUpdateTenantDocument();
        allow delete: if isSuperAdmin();
      }
    }

    match /blogCategories/{blogCategoryId} {
      allow read: if true;
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();

      match /{path=**}/translations/{translationId} {
        allow read: if true;
        allow create: if canAdminWriteTenantDocument(request.resource.data);
        allow update: if canUpdateTenantDocument();
        allow delete: if isSuperAdmin();
      }
    }

    match /blogTags/{blogTagId} {
      allow read: if true;
      allow create: if canAdminWriteTenantDocument(request.resource.data);
      allow update: if canUpdateTenantDocument();
      allow delete: if isSuperAdmin();

      match /{path=**}/translations/{translationId} {
        allow read: if true;
        allow create: if canAdminWriteTenantDocument(request.resource.data);
        allow update: if canUpdateTenantDocument();
        allow delete: if isSuperAdmin();
      }
    }

    match /carts/{userId} {
      match /items/{itemId} {
        allow get: if canCustomerGetCartItem(resource.data, userId, itemId);
        allow list: if isUser(userId);
        allow create: if canCustomerWriteCartDocument(userId);
        allow update: if canCustomerUpdateCartDocument(userId);
        allow delete: if canCustomerDeleteCartDocument(userId);
      }

      match /preflight/{jobId} {
        allow read: if canCustomerReadCartDocument(resource.data, userId);
        allow write: if false;
      }
    }

    match /assistantConversations/{conversationId} {
      allow read: if isSignedInOwner(resource.data.userId)
        && (!hasTenantId(resource.data)
          || customerHasTenant(request.auth.uid, resource.data.tenantId));
      allow create: if canCreateAssistantConversation();
      allow update: if canUpdateAssistantConversation();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isAssistantConversationOwner(conversationId);
        allow create: if isAssistantConversationOwner(conversationId)
          && request.resource.data.conversationId == conversationId
          && request.resource.data.role in ["user", "system", "assistant"]
          && request.resource.data.parts is list;
        allow update: if isAssistantConversationOwner(conversationId)
          && request.resource.data.conversationId == resource.data.conversationId
          && request.resource.data.role == resource.data.role;
        allow delete: if false;
      }
    }
  }
}
