# CI and local build helpers
NEXT_TURBOPACK_EXPERIMENTAL_USE_SYSTEM_TLS_CERTS=1
SKIP_GOOGLE_FONTS=false
SKIP_STATIC_PARAMS_DURING_CI_BUILD=false
ANALYZE=false

# Deployment mode and tenancy
# Dedicated deployments keep the current single-customer behavior:
# deployment mode dedicated, tenant default, and tenant enforcement disabled.
# SaaS deployments should not set KONFI_TENANT_ID; tenant context is resolved
# from the request domain or the authenticated user's tenant membership.
KONFI_DEPLOYMENT_MODE=dedicated
KONFI_TENANT_ID=default
KONFI_REQUIRE_TENANT_ID=false
NEXT_PUBLIC_KONFI_DEPLOYMENT_MODE=dedicated
NEXT_PUBLIC_KONFI_REQUIRE_TENANT_ID=false

# Core app URLs
# Dedicated-only: these point at one customer's admin/store deployment.
# Do not copy customer-specific URLs into shared SaaS runtime config.
NEXT_PUBLIC_STORE_URL=http://localhost:3000
STORE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_STORE_LOCAL_URL=http://localhost:3000
NEXT_PUBLIC_STORE_DEV_URL=http://localhost:3000
NEXT_PUBLIC_STORE_DEV_PORT=3000

# Firebase client configuration
NEXT_PUBLIC_FIREBASE_STORE_API_KEY=demo-store-api-key
NEXT_PUBLIC_FIREBASE_ADMIN_API_KEY=demo-admin-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-project
# Optional Firestore database ID. Leave empty for "(default)"; use "default"
# for the Konfi Cloud SaaS runtime named database.
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_STORE_APP_ID=1:000000000000:web:store000000000000000
NEXT_PUBLIC_FIREBASE_ADMIN_APP_ID=1:000000000000:web:admin000000000000000
NEXT_PUBLIC_FIREBASE_STORE_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
NEXT_PUBLIC_FIREBASE_VAP_ID=
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN_ADMIN=
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN_STORE=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Firebase server credentials
# ADMIN_FIREBASE_SERVICE_ACCOUNT is the private key string expected by the
# admin/store server code, not the full Firebase service-account JSON object.
ADMIN_FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
ADMIN_FIREBASE_SERVICE_ACCOUNT=-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n
STORAGE_BUCKET=demo-project.appspot.com

# Store and company metadata
# Dedicated-only: these are single-customer storefront runtime values.
# They are unsafe for shared SaaS runtime config; resolve SaaS branding,
# contact, channel, bank, and CDN values from tenant/domain records instead.
NEXT_PUBLIC_STORE_CHANNEL_ID=demo-channel
STORE_CHANNEL_ID=demo-channel
NEXT_PUBLIC_LINKED_CHANNEL_IDS=
NEXT_PUBLIC_STORE_NAME=Konfi Demo Store
NEXT_PUBLIC_STORE_DESCRIPTION=Configurable printing storefront
NEXT_PUBLIC_CDN_URL=https://cdn.example.com
NEXT_PUBLIC_FILES_MAIL=files@example.com
NEXT_PUBLIC_SUPPORT_MAIL=support@example.com
NEXT_PUBLIC_CONTACT_MAIL=contact@example.com
LONG_COMPANY_NAME=Example Company Sp. z o.o.
SHORT_COMPANY_NAME=Example
COMPANY_DESCRIPTION=Example print shop
COMPANY_MAIN_COLOR=#111827
NEXT_PUBLIC_LEGAL_COMPANY_NAME=Example Company
NEXT_PUBLIC_SHORT_COMPANY_NAME=Example
NEXT_PUBLIC_LONG_COMPANY_NAME=Example Company
NEXT_PUBLIC_COMPANY_DESCRIPTION=Example print shop
NEXT_PUBLIC_COMPANY_MAIN_COLOR=#111827
NEXT_PUBLIC_COMPANY_SECONDARY_COLOR=#2563eb
NEXT_PUBLIC_COMPANY_STREET_ADDRESS=Example Street 1
NEXT_PUBLIC_COMPANY_CITY=Example City
NEXT_PUBLIC_COMPANY_POSTAL_CODE=00-000
NEXT_PUBLIC_COMPANY_ADDRESS_LOCALITY=Example Region
NEXT_PUBLIC_COMPANY_PHONE_NUMBER=+48000000000
NEXT_PUBLIC_COMPANY_MAIL=company@example.com
NEXT_PUBLIC_COMPANY_COUNTRY_CODE=PL
NEXT_PUBLIC_VAT_ID=PL0000000000
NEXT_PUBLIC_BANK_NAME=Example Bank
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER=00000000000000000000000000
NEXT_PUBLIC_FACEBOOK_NAME=
NEXT_PUBLIC_INSTAGRAM_NAME=
NEXT_PUBLIC_FOOTER_ADDIITIONAL_LINK=
NEXT_PUBLIC_FOOTER_ADDIITIONAL_LINK_TEXT=
NEXT_PUBLIC_FOOTER_ADDIITIONAL_LINK_IMAGE=

# Email
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
PRODUCTION_COOPERATION_APP_API_SECRET=replace-with-direct-app-api-32-byte-secret
PRODUCTION_COOPERATION_CLOUD_CALLBACK_SECRET=replace-with-cloud-callback-32-byte-secret
PRODUCTION_COOPERATION_CALLBACK_ALLOWED_ORIGINS=https://cloud.example.com
NO_REPLY_EMAIL=noreply@example.com
NOTIFICATIONS_EMAIL=notifications@example.com
REPORT_EMAIL=reports@example.com
RESEND_NEW_ORDER_CUSTOMER_TEMPLATE_ID=
RESEND_NEW_ORDER_ADMIN_TEMPLATE_ID=
RESEND_ATTACHMENT_TEMPLATE_ID=
RESEND_NEW_COMPLAINT_TEMPLATE_ID=
RESEND_NEW_CAMPAIGN_TEMPLATE_ID=
RESEND_NEWSLETTER_PROMOTION_TEMPLATE_ID=

# Payments and webhook auth
STRIPE_SECRET_KEY=
STRIPE_SECRET_KEY_DEV=
STRIPE_PUBLIC_KEY=
STRIPE_PUBLIC_KEY_DEV=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_DEV=
PRZELEWY24_POS_ID=
PRZELEWY24_ORDER_KEY=
PRZELEWY24_CRC=
PRZELEWY24_CRC_DEV=
PRZELEWY24_API_KEY=
PRZELEWY24_API_KEY_DEV=
REVALIDATE_SECRET=replace-me
KONFI_STOREFRONT_EDITOR_SECRET=replace-me-with-a-long-random-secret
CRON_SECRET=replace-me
FRONTEND_REVALIDATE_URL=http://localhost:3000/api/revalidate

# Search, maps, and analytics
# Search backend: auto uses Firestore full-text search in SaaS and
# Meilisearch in dedicated. Set to firestore to move a dedicated runtime after
# Firestore Enterprise Native mode text indexes are ready.
KONFI_SEARCH_BACKEND=auto
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_ADMIN_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NEXT_PUBLIC_INPOST_GEOWIDGET_TOKEN=
NEXT_PUBLIC_SEARXNG_URL=
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_ANALYTICS_PROPERTY_ID=
MERCHANT_ID=
MERCHANT_DATA_SOURCE=

# AI
AI_GATEWAY_API_KEY=
# Paid Vercel AI Gateway image models (for example Flux Klein / GPT Image 2)
# require purchased Gateway credits or top-up. Keep disabled for free-tier keys.
AI_GATEWAY_PAID_IMAGE_MODELS_ENABLED=false
NEXT_PUBLIC_AI_GATEWAY_PAID_IMAGE_MODELS_ENABLED=false
AI_REFERENCE_IMAGE_ALLOWED_HOSTS=

# External integrations
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_REDIRECT_URI=http://localhost:3001/api/auth/callback/allegro
ALLEGRO_SANDBOX=true
FAKTUROWNIA_API_KEY=
FAKTUROWNIA_SUBDOMAIN=
KONFI_INTEGRATION_SECRETS_ACTIVE_KEY_VERSION=
# JSON object mapping key version → key value; ACTIVE_KEY_VERSION selects the version used for new encryptions.
# Each key value may be a 64-char hex string (decoded to 32 bytes), a "base64:<base64>" string (must decode to 32 bytes),
# or a 32-byte UTF-8 string. Example: {"2026-06":"<64-hex-chars>"}
KONFI_INTEGRATION_SECRETS_KEYRING=
# Meta (Facebook/Instagram) social scheduler — dedicated mode only.
# In SaaS mode, per-tenant credentials are stored in Firestore instead.
META_APP_ID=
META_APP_SECRET=
# Graph API version used for all Meta calls (default v23.0 when unset).
META_GRAPH_API_VERSION=
FAKTUROWNIA_INVOICE_UPDATE_WEBHOOK_TOKEN=
FAKTUROWNIA_INVOICE_UPDATE_WEBHOOK_DEDICATED_MODE=false
FAKTUROWNIA_INVOICE_UPDATE_WEBHOOK_CHANNEL_IDS=demo-channel
POLKURIER_HOST=
POLKURIER_LOGIN=
POLKURIER_TOKEN=
EPAKA_API_URL=
EPAKA_AUTH_URL=
EPAKA_CLIENT_ID=
EPAKA_CLIENT_SECRET=
EPAKA_REDIRECT_URI=http://localhost:3001/api/auth/epaka/callback
EPAKA_ACCESS_TOKEN=
EPAKA_BEARER_TOKEN=
EPAKA_TOKEN=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/callback/microsoft
MICROSOFT_TENANT_ID=
MICROSOFT_SCOPES=
ENCRYPTION_SECRET=replace-with-32-byte-secret
SESSION_SECRET=replace-with-session-secret
# Optional dedicated key for the Meta OAuth state cookie (falls back to SESSION_SECRET); use >=32 random bytes.
META_OAUTH_STATE_SECRET=
# Social scheduler feature flag — set to "true" to enable in production; dev always has it on.
NEXT_PUBLIC_SOCIAL_SCHEDULER_ENABLED=

# Desktop
KONFI_DESKTOP_ADMIN_URL=http://localhost:3001
KONFI_DESKTOP_DEV_ADMIN_URL=http://localhost:3001
KONFI_DESKTOP_COMPANY_URL=https://example.com
KONFI_DESKTOP_ALLOWED_ORIGINS=
DESKTOP_UPDATER_GITHUB_TOKEN=
DESKTOP_UPDATER_REPO_OWNER=
DESKTOP_UPDATER_REPO_NAME=

# Observability
NEXT_PUBLIC_SENTRY_DSN_STORE=
NEXT_PUBLIC_SENTRY_DSN_ADMIN=
SENTRY_ORG=
SENTRY_PROJECT_STORE=
SENTRY_PROJECT_ADMIN=
SENTRY_AUTH_TOKEN_STORE=
SENTRY_AUTH_TOKEN_ADMIN=

# Firebase functions
FUNCTION_NAME=
